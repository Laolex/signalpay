# ── Arc Testnet ──────────────────────────────────────────────
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Deployer / provider wallet (used by contract deploy scripts + provider server)
PRIVATE_KEY=
# Separate key used by the LangGraph buyer agent to sign EIP-3009 authorizations
# and to post ERC-8004 feedback. Falls back to PRIVATE_KEY if unset — not
# recommended, since it reuses the provider's hot key.
BUYER_PRIVATE_KEY=

# ── Contracts ────────────────────────────────────────────────
# Populate after `forge script script/Deploy.s.sol:DeploySignalRegistry ...`
SIGNAL_REGISTRY_ADDRESS=

# ── Circle Nanopayments ──────────────────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Base URL for Circle Gateway (used as a fallback facilitator)
NANOPAYMENTS_API_URL=https://gateway-api-testnet.circle.com/gateway/v1

# ── x402 facilitator ────────────────────────────────────────
# Point this at whatever facilitator settles your x402 payloads. Examples:
#   https://channels.openzeppelin.com/x402/testnet  (OpenZeppelin Relayer)
#   <Circle's x402 facilitator URL when published>
# If left blank, the server will POST to `${NANOPAYMENTS_API_URL}${X402_SETTLE_PATH}`.
X402_FACILITATOR_URL=
X402_SETTLE_PATH=/x402/settle
X402_VERIFY_PATH=/x402/verify

# DEV-ONLY escape hatch. MUST be "0" (or unset) in production. When "1",
# x402.validate_payment returns a simulated receipt if the facilitator is
# unreachable — and logs loudly so it can't ship silently.
X402_DEV_MODE=0

# ── Backend ──────────────────────────────────────────────────
PROVIDER_WALLET=0x...
SIGNALPAY_API_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins for the FastAPI server.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

# ── Optional ─────────────────────────────────────────────────
ETHERSCAN_API_KEY=
