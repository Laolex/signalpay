# ── SignalPay frontend env ──────────────────────────────────
# Arc Testnet SignalRegistry address. Falls back to the pinned hackathon
# deployment in `src/wagmi.ts` if unset.
VITE_SIGNAL_REGISTRY_ADDRESS=

# API base the frontend calls. Default `http://localhost:8000`.
VITE_API_BASE=http://localhost:8000
